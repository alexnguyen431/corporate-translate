# Required for /api/translate (set in Vercel Project → Environment Variables)
ANTHROPIC_API_KEY=

# Optional: comma-separated origins for CORS in production (e.g. https://yourdomain.com)
# If unset, same Vercel deployment origin is allowed when VERCEL_URL is set.
ALLOWED_ORIGINS=

# Optional: salt for hashing IPs in server logs
IP_HASH_SALT=

# Optional: public site URL (match index.html canonical / og:url when you use a custom domain)
# VITE_SITE_URL=https://your-domain.com
